{
  "name": "@sableclient/twemoji-font",
  "version": "1.0.0",
  "private": false,
  "description": "Sable-maintained Twemoji COLR font package for web apps.",
  "keywords": [
    "colr",
    "emoji",
    "twemoji",
    "unicode"
  ],
  "homepage": "https://github.com/SableClient/twemoji-font#readme",
  "bugs": {
    "url": "https://github.com/SableClient/twemoji-font/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SableClient/twemoji-font.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.css",
  "exports": {
    ".": {
      "sass": "./dist/index.css",
      "default": "./dist/index.css"
    },
    "./*": {
      "sass": "./dist/*.css",
      "default": "./dist/*.css"
    },
    "./*.css": {
      "sass": "./dist/*.css",
      "default": "./dist/*.css"
    },
    "./files/*": {
      "sass": "./dist/files/*",
      "default": "./dist/files/*"
    },
    "./files/*.woff2": {
      "sass": "./dist/files/*.woff2",
      "default": "./dist/files/*.woff2"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build:font": "node scripts/build-font.ts",
    "build:package": "node scripts/package/build-package.ts",
    "build:release-assets": "node scripts/package/build-release-assets.ts",
    "build": "vp run build:font && vp run build:package",
    "typecheck": "tsc -p tsconfig.json",
    "smoke": "node scripts/package/smoke-test-package.ts",
    "check:upstream": "node scripts/upstream/check-upstream.ts",
    "prepare:upstream": "node scripts/upstream/publish-prepare.ts",
    "check:repeatability": "node scripts/verify/check-build-repeatability.ts",
    "test": "vp test run",
    "lint": "vp lint",
    "fmt": "vp fmt",
    "check": "vp check",
    "verify": "vp run build && vp run test && vp run typecheck && vp run smoke && vp run check:repeatability"
  },
  "dependencies": {
    "emojibase-data": "^17.0.0",
    "unzipper": "^0.12.3",
    "xml2js": "^0.6.2",
    "xmlbuilder": "^15.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "@types/unzipper": "^0.10.11",
    "@types/xml2js": "^0.4.14",
    "@types/yazl": "^3.3.1",
    "@voidzero-dev/vite-plus-core": "^0.1.18",
    "svgo": "^4.0.1",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.18",
    "vitest": "^4.1.4",
    "yazl": "^3.3.1"
  },
  "engines": {
    "node": "24.14.1"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.18",
      "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.18"
    }
  },
  "twemoji": {
    "version": "17.0.2",
    "commit": "40c2213f8f9bc53b1188fdae325a63a82ffb5bec",
    "source": "https://github.com/jdecked/twemoji/tree/40c2213f8f9bc53b1188fdae325a63a82ffb5bec/v/17.0.2/svg"
  }
}